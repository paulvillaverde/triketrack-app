{
  "expo": {
    "name": "triketrack-app",
    "slug": "triketrack-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/adaptive-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/adaptive-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#57C7A8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.triketrackapp",
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/adaptive-icon.png",
      "shortName": "TrikeTrack",
      "display": "standalone",
      "themeColor": "#57C7A8",
      "backgroundColor": "#F5F6F8",
      "scope": "./",
      "startUrl": "./"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow TrikeTrack to access your contacts so we can complete trusted device onboarding on this phone."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow TrikeTrack to access your location so trip tracking stays accurate and follows the real road."
        }
      ],
      "@maplibre/maplibre-react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "f68b2845-3772-4020-b6d5-a8adfabf761c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f68b2845-3772-4020-b6d5-a8adfabf761c"
    }
  }
}
